# Shared
DATA_DIR=./data
PROJECT_ROOT=.

# When the collector runs as root, set this so JSON under DATA_DIR is chowned for the web server user (optional group).
# COLLECTOR_DATA_USER=franck
# COLLECTOR_DATA_GROUP=franck

# Web (HTTPS only — requires certs; see certs/README.md)
# Public site URL for canonical links and Open Graph (strongly recommended behind a reverse proxy).
# PUBLIC_SITE_URL=https://your-domain.example

LISTEN=:8082
# Defaults match gen_dev_certs.sh; production often uses Let's Encrypt names, e.g. TLS_CERT_FILE=certs/fullchain.pem TLS_KEY_FILE=certs/key.pem (readable by the systemd User).
TLS_CERT_FILE=certs/cert.pem
TLS_KEY_FILE=certs/key.pem

# Optional: connection probes (separate hostnames in DNS + TLS SAN; all serve GET /api/healthz)
# PROBE_V4_URL=https://ipv4.example.com/api/healthz
# PROBE_V6_URL=https://ipv6.example.com/api/healthz
# PROBE_DS_URL=https://pacific.example.com/api/healthz
# CORS on GET /api/healthz for cross-origin probe fetches (on every probe vhost). Default *.
# Production: canonical site origin. Local dev: add both loopback hostnames (comma-separated).
# HEALTHZ_CORS_ALLOW_ORIGIN=https://pacific.example.com,https://127.0.0.1:8082,https://localhost:8082

# Skip Hurricane Electric bgp.he.net country scrape (keep last snapshot in JSON).
# COLLECTOR_SKIP_HE_BGP=1

# Daemon: one economy per interval (production often 4h; dev default in code is 10m).
# COLLECTOR_PER_COUNTRY_INTERVAL=4h

# RPKI via RIPEstat (stat.ripe.net). Register app with stat@ripe.net if volume grows.
# COLLECTOR_SKIP_RPKI=1
# COLLECTOR_RPKI_MAX_PREFIXES_PER_ASN=10
# COLLECTOR_RPKI_REFRESH_INTERVAL=168h
# COLLECTOR_RPKI_MIN_INTERVAL=300ms
# RIPESTAT_SOURCEAPP=pacific-ipv6-monitor

# Timeouts
DNS_TIMEOUT=5s
HTTP_CLIENT_TIMEOUT=15s
SMTP_TIMEOUT=10s
CHECK_DOMAIN_DEADLINE=120s
