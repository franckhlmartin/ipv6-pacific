# Shared
DATA_DIR=./data
PROJECT_ROOT=.

# When the collector runs as root, set this so JSON under DATA_DIR is chowned for the web server user (optional group).
# COLLECTOR_DATA_USER=franck
# COLLECTOR_DATA_GROUP=franck

# Web (HTTPS only — requires certs; see certs/README.md)
LISTEN=:8082
# Defaults match gen_dev_certs.sh; production often uses Let's Encrypt names, e.g. TLS_CERT_FILE=certs/fullchain.pem TLS_KEY_FILE=certs/key.pem (readable by the systemd User).
TLS_CERT_FILE=certs/cert.pem
TLS_KEY_FILE=certs/key.pem

# Optional: dual-stack border when both URLs respond (separate v4-only and v6-only hostnames in DNS + TLS SAN)
# PROBE_V4_URL=https://v4.example.com/api/healthz
# PROBE_V6_URL=https://v6.example.com/api/healthz
# CORS on GET /api/healthz for those probes (main site fetch). Default * ; set one origin if you prefer.
# HEALTHZ_CORS_ALLOW_ORIGIN=https://pacific.example.com

# Collector daemon
COLLECTOR_PER_COUNTRY_INTERVAL=10m

# Timeouts
DNS_TIMEOUT=5s
HTTP_CLIENT_TIMEOUT=15s
SMTP_TIMEOUT=10s
CHECK_DOMAIN_DEADLINE=120s
